{
    "compilerOptions": {
        "jsx": "react",
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "paths": {
            "app/*": [
                "./src/app/*"
            ],
            "components/*": [
                "./src/components/*"
            ],
            "features/*": [
                "./src/features/*"
            ],
            "mocks/*": [
                "./src/mocks/*"
            ],
            "styles/*": [
                "./src/styles/*"
            ],
            "types/*": [
                "./src/types/*"
            ],
            "utils/*": [
                "./src/utils/*"
            ]
        },
        "removeComments": true,
        "declaration": false,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "strict": true,
        "sourceMap": true,
        "allowJs": true,
        "noEmit": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "skipLibCheck": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true
    },
    "include": [
        "src/**/*",
        "temp/**/*",
        "eslint.config.js",
        "vite.config.ts",
        "vitest.config.ts",
        "postcss.config.js",
        "react-router.config.ts"
    ],
    "exclude": []
}
