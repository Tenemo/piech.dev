{
    "name": "piech.dev",
    "version": "1.0.0",
    "author": "Piotr Piech <piotr@piech.dev>",
    "license": "UNLICENSED",
    "description": "My personal page. It turned into a complex project itself: it supports loading all projects' information directly from GitHub, renders markdown, the whole site is pre-rendered and served with zero JS. It includes dynamic <meta> tags for each project, including og:image tags with sizes. Perfect 100/100/100/100 Lighthouse score for all routes.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Tenemo/piech.dev.git"
    },
    "bugs": {
        "url": "https://github.com/Tenemo/piech.dev/issues"
    },
    "homepage": "https://github.com/Tenemo/piech.dev#readme",
    "scripts": {
        "predev": "node --experimental-strip-types src/utils/fetchGithubData.ts",
        "dev": "node scripts/react-router-cli.cjs dev",
        "prebuild": "node --experimental-strip-types src/utils/fetchGithubData.ts && npm run lint && npm run tsc && npm test",
        "build": "node scripts/react-router-cli.cjs build",
        "postbuild": "node --experimental-strip-types src/utils/transformImagePaths.ts && node --experimental-strip-types src/utils/inlineCss.ts && rimraf dist/server && rimraf dist/client/assets && rimraf --glob \"dist/client/**/*.js\" && node --experimental-strip-types src/utils/generateSitemap.ts",
        "prebuild:skip": "node --experimental-strip-types src/utils/fetchGithubData.ts",
        "build:skip": "node scripts/react-router-cli.cjs build",
        "postbuild:skip": "npm run postbuild",
        "build:analyze": "cross-env ANALYZE=true node scripts/react-router-cli.cjs build",
        "eslint": "eslint . -c eslint.config.js --no-error-on-unmatched-pattern",
        "eslint:fix": "eslint . --fix -c eslint.config.js --no-error-on-unmatched-pattern",
        "github-refetch": "node --experimental-strip-types src/utils/fetchGithubData.ts --refetch",
        "stylelint": "stylelint **/*.scss **/*.css",
        "lint": "npm run eslint && npm run stylelint",
        "preview": "vite preview --outDir dist/client",
        "tsc": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "prepare": "husky"
    },
    "browserslist": [
        "> 1%",
        "not IE > 0",
        "not op_mini all"
    ],
    "engines": {
        "node": ">=22.18.0"
    },
    "type": "module",
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.9",
        "@mui/material": "^7.3.9",
        "date-fns": "^4.1.0",
        "history": "^5.3.0",
        "image-size": "^2.0.2",
        "normalize.css": "^8.0.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.1.1",
        "react-markdown": "^10.1.0",
        "react-router": "^7.13.2",
        "react-syntax-highlighter": "^16.1.1",
        "rehype-raw": "^7.0.0",
        "remark-gfm": "^4.0.1"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@julr/vite-plugin-validate-env": "^2.2.2",
        "@react-router/dev": "^7.13.2",
        "@react-router/node": "^7.13.2",
        "@react-router/serve": "^7.13.2",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/eslint": "^9.6.1",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/react-router": "^5.1.20",
        "@types/react-router-dom": "^5.3.3",
        "@types/react-syntax-highlighter": "^15.5.13",
        "@vitest/coverage-v8": "^4.1.1",
        "@vitest/eslint-plugin": "^1.6.13",
        "autoprefixer": "^10.4.27",
        "browserslist-to-esbuild": "^2.1.1",
        "cross-env": "^10.1.0",
        "cssnano": "^7.1.3",
        "dotenv": "^17.3.1",
        "eslint": "10.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-only-error": "^1.0.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.4.0",
        "html-webpack-plugin": "^5.6.6",
        "husky": "^9.1.7",
        "jsdom": "^29.0.1",
        "postcss-flexbugs-fixes": "^5.0.2",
        "prettier": "^3.8.1",
        "prettier-eslint": "^16.4.2",
        "prettier-stylelint": "^0.4.2",
        "rimraf": "^6.1.3",
        "rollup-plugin-visualizer": "^7.0.1",
        "sass": "^1.98.0",
        "schema-dts": "^2.0.0",
        "sitemap": "^9.0.1",
        "stylelint": "^17.5.0",
        "stylelint-config-recommended": "^18.0.0",
        "stylelint-config-recommended-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2",
        "vite": "^8.0.2",
        "vite-css-modules": "^1.15.0",
        "vitest": "^4.1.1"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.60.0"
    }
}
